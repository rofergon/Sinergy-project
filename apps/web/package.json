    "cosmjs-types": "^0.11.0",
    "lightweight-charts": "^5.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "viem": "^2.39.0",
    "vite-plugin-node-polyfills": "^0.26.0",
    "wagmi": "^2.17.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"

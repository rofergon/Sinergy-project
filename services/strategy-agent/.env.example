AGENT_PORT=8790
AGENT_MATCHER_URL=http://127.0.0.1:8787
AGENT_DB_FILE=../matcher/data/strategies.sqlite

# OpenAI API Configuration
AGENT_MODEL_BASE_URL=https://api.openai.com/v1
AGENT_MODEL_NAME=gpt-5.4-nano
AGENT_MODEL_API_KEY=sk-your-openai-api-key-here

# GPT-5.4 Reasoning Configuration (none, low, medium, high, xhigh)
# For gpt-5.4-nano, recommended: low or none for cost efficiency
AGENT_MODEL_REASONING_EFFORT=low

AGENT_MODEL_TIMEOUT_MS=60000
AGENT_MAX_STEPS=6
AGENT_TOOLCALL_RETRIES=2
AGENT_FORCE_FALLBACK_JSON=false
